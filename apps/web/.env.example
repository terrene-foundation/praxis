# Praxis Web Dashboard Environment Configuration
# Copy to .env and adjust values as needed.

# API server URL (the Praxis backend running on Nexus)
VITE_PRAXIS_API_URL=http://localhost:8000

# WebSocket server URL
VITE_PRAXIS_WS_URL=ws://localhost:8000

# Enable development mode (shows quick-login button on login page)
VITE_DEV_MODE=true
